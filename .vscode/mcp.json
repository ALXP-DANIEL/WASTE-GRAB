{
	"servers": {
		"nx": {
			"type": "stdio",
			"command": "npm",
			"args": [
				"exec",
				"--",
				"nx",
				"mcp",
				"--minimal"
			]
		},
		"serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"serena-agent",
				"serena",
				"start-mcp-server",
				"--project",
				"${workspaceFolder}"
			]
		},
		"caveman": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"caveman-mcp"
			]
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"my-mcp-server-11bdb29e": {
			"type": "stdio",
			"command": "serena",
			"args": [
				"start-mcp-server",
				"--context=vscode",
				"--project",
				"${workspaceFolder}"
			]
		}
	},
	"inputs": []
}