generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  CUSTOMER
  COLLECTOR
  ADMIN
}

enum PickupStatus {
  PENDING
  ACCEPTED
  ARRIVED
  VERIFIED
  COMPLETED
  CANCELLED
}

enum ImageType {
  USER_UPLOAD
  COLLECTOR_PROOF
}

enum TransactionType {
  PAYMENT
  POINTS_REDEEMED
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

model User {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  role         UserRole  @default(CUSTOMER)
  createdAt    DateTime  @default(now()) @map("created_at")
  address      Address[]

  pickupRequestsAsUser      PickupRequest[] @relation("UserRequests")
  pickupRequestsAsCollector PickupRequest[] @relation("CollectorRequests")
  transactions              Transaction[]

  @@map("users")
}

model WasteCategory {
  id          String       @id @default(uuid())
  name        String       @db.VarChar(100)
  pricePerKg  Decimal      @db.Decimal(10, 2)
  pointsPerKg Int          @default(1)
  isBanned    Boolean      @default(false)
  description String?      @db.Text
  pickupItems PickupItem[]

  @@map("waste_categories")
}

model Address {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  label            String   @db.VarChar(100)
  street           String   @db.Text
  city             String   @db.VarChar(100)
  state            String   @db.VarChar(100)
  postalCode       String   @db.VarChar(20)
  formattedAddress String?  @map("formatted_address") @db.Text
  googlePlaceId    String?  @map("google_place_id") @db.VarChar(255)
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  notes            String?  @db.Text
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("address")
}

model PickupRequest {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  collectorId String?      @map("collector_id")
  addressText String       @map("address_text") @db.Text
  status      PickupStatus @default(PENDING)

  aiClassificationLabel String?  @map("ai_classification_label") @db.VarChar(100)
  aiConfidence          Decimal? @map("ai_confidence") @db.Decimal(5, 2)

  estimatedPrice Decimal? @map("estimated_price") @db.Decimal(10, 2)
  finalPrice     Decimal? @map("final_price") @db.Decimal(10, 2)

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  user         User          @relation("UserRequests", fields: [userId], references: [id])
  collector    User?         @relation("CollectorRequests", fields: [collectorId], references: [id])
  items        PickupItem[]
  images       PickupImage[]
  transactions Transaction[]

  @@map("pickup_requests")
}

model PickupItem {
  id              String   @id @default(uuid())
  pickupRequestId String   @map("pickup_request_id")
  categoryId      String   @map("category_id")
  estimatedWeight Decimal? @map("estimated_weight") @db.Decimal(10, 2)
  actualWeight    Decimal? @map("actual_weight") @db.Decimal(10, 2)

  pickupRequest PickupRequest @relation(fields: [pickupRequestId], references: [id], onDelete: Cascade)
  category      WasteCategory @relation(fields: [categoryId], references: [id])

  @@map("pickup_items")
}

model PickupImage {
  id              String    @id @default(uuid())
  pickupRequestId String    @map("pickup_request_id")
  imageUrl        String    @map("image_url") @db.Text
  imageType       ImageType @map("image_type")
  uploadedAt      DateTime  @default(now()) @map("uploaded_at")

  pickupRequest PickupRequest @relation(fields: [pickupRequestId], references: [id], onDelete: Cascade)

  @@map("pickup_images")
}

model Transaction {
  id              String            @id @default(uuid())
  pickupRequestId String            @map("pickup_request_id")
  userId          String            @map("user_id")
  amount          Decimal           @db.Decimal(10, 2)
  type            TransactionType   @map("type")
  status          TransactionStatus @default(SUCCESS)
  createdAt       DateTime          @default(now()) @map("created_at")

  pickupRequest PickupRequest @relation(fields: [pickupRequestId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@map("transactions")
}

// Collection locations where collectors can deliver waste.
model Location {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(255)
  address       String?  @db.Text
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(100)
  postalCode    String?  @db.VarChar(20)
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  googlePlaceId String?  @map("google_place_id") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by")

  @@map("locations")
}
