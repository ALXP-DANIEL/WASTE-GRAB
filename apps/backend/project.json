{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend/src",
  "projectType": "application",
  "tags": ["scope:backend"],
  "release": {
    "docker": {
      "repositoryName": "wastegrab/backend"
    }
  },
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["prisma:generate", "^build"],
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "apps/backend/dist",
        "format": ["esm"],
        "bundle": false,
        "main": "apps/backend/src/main.ts",
        "tsConfig": "apps/backend/tsconfig.app.json",
        "assets": ["apps/backend/src/assets", "apps/backend/prisma"],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "generateLockfile": true,
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "backend:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "backend:build:development"
        },
        "production": {
          "buildTarget": "backend:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "dependsOn": ["prisma:generate"]
    },
    "prisma:generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend",
        "command": "prisma generate"
      }
    },
    "prisma:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend",
        "command": "prisma migrate dev"
      }
    },
    "prisma:studio": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend",
        "command": "prisma studio"
      }
    },
    "db:push": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend",
        "command": "prisma db push"
      }
    },
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/backend/Dockerfile -t wastegrab-backend ."
      }
    }
  }
}
