{
  "name": "shared-types",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/types/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:types"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/types",
        "main": "libs/shared/types/src/index.ts",
        "tsConfig": "libs/shared/types/tsconfig.lib.json",
        "format": ["esm"],
        "bundle": true,
        "platform": "neutral",
        "declaration": true,
        "assets": ["libs/shared/types/*.md", "libs/shared/types/package.json"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/shared/types/tsconfig.lib.json --noEmit --module esnext"
      }
    }
  }
}
