{
  "name": "wastegrab-backend",
  "version": "1.0.0",
  "description": "Simple Express todo API for WasteGrab.",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "db:push": "prisma db push",
    "dev": "prisma generate && tsx watch src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "start": "node dist/server.js",
    "typecheck": "prisma generate && tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@wastegrab/shared": "file:../shared",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
